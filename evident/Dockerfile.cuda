# Proteon EVIDENT reproducibility image — CUDA variant.
#
# Mirrors evident/Dockerfile (the :slim image) but:
#   1. Builds proteon-connector with --features cuda so the GPU code
#      paths compile in (cudarc + proteon-search/cuda + the embedded
#      .cu kernels compiled at runtime via NVRTC).
#   2. Runs on top of nvidia/cuda:12.8.2-runtime-ubuntu24.04 so the
#      runtime CUDA libs (libcudart, libnvrtc) are present and host
#      libcuda is forwarded by `docker run --gpus all`.
#
# Build (from proteon repo root):
#   docker build -f evident/Dockerfile.cuda -t proteon-evident:cuda .
# Run (host needs nvidia-container-runtime):
#   docker run --rm --gpus all proteon-evident:cuda evident list evident/evident.yaml
#
# Why a separate Dockerfile rather than a target in evident/Dockerfile:
# the runtime base differs (nvidia/cuda Ubuntu 24.04 vs the slim
# image's python:3.13-slim-trixie). All three stages of THIS file are
# pinned to ubuntu:24.04-glibc binaries (noble, glibc 2.39) so the
# proteon-connector cdylib and the oracle binaries link against the
# same glibc the runtime stage provides. Slim is trixie-everywhere;
# this image is noble-everywhere.
#
# noble ships Python 3.12, gcc-13, libstdc++-13, and CMake 3.28 in
# default apt — no PPAs (deadsnakes, ubuntu-toolchain-r, Kitware) and
# therefore no Launchpad runtime dependency. Earlier jammy-based
# revisions broke whenever Launchpad's API or CDN had a transient
# outage; the move to noble removes that fragility entirely.
#
# CUDA version: cudarc 0.19's cuda-12050 feature compiles against 12.5
# headers; CUDA's minor-version forward-compat makes 12.8.2 runtime fine
# for code built against 12.5. NVIDIA does not publish a 12.5+noble image
# tag (only 22.04 and 20.04); 12.8.2 is the lowest 12.x available on
# noble.

# ---------------------------------------------------------------------------
# Stage 1: Rust builder.
#
# Built on ubuntu:24.04 (noble, glibc 2.39) — matches the runtime stage
# below (nvidia/cuda:12.8.2-runtime-ubuntu24.04). noble ships Python
# 3.12 + gcc-13 in default apt, so neither deadsnakes nor
# ubuntu-toolchain-r PPAs are needed; the build has zero Launchpad
# dependencies. (Earlier commits used jammy + deadsnakes, which broke
# whenever Launchpad's API or CDN had a transient outage.)
#
# Rust comes from rustup rather than the official rust:1.88 image
# because that image is debian-based and reintroduces a glibc mismatch.
# cudarc loads libcuda at runtime via dlopen, so the builder does NOT
# need a CUDA SDK; the runtime stage forwards host libcuda through the
# NVIDIA Container Runtime.
# ---------------------------------------------------------------------------
FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PATH=/root/.cargo/bin:/opt/build-venv/bin:${PATH}

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl \
        build-essential pkg-config git \
        python3 python3-dev python3-venv python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Rust 1.88+ required: cudarc's transitive dep libloading@0.9.0 bumped
# its MSRV to 1.88. Pinned profile=minimal — no rustfmt/clippy, no
# rust-docs; the builder only needs cargo + rustc.
ARG RUST_VERSION=1.88.0
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain "${RUST_VERSION}" --profile minimal

RUN python3 -m venv /opt/build-venv && \
    /opt/build-venv/bin/pip install --no-cache-dir maturin build

WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY proteon-align       ./proteon-align/
COPY proteon-io          ./proteon-io/
COPY proteon-arrow       ./proteon-arrow/
COPY proteon-search      ./proteon-search/
COPY proteon-bin         ./proteon-bin/
COPY proteon-connector   ./proteon-connector/
COPY packages            ./packages/
COPY validation          ./validation/
COPY README.md LICENSE THIRD_PARTY_NOTICES.md VERSION ./

# Wheel 1: proteon-connector with cuda feature on. Compiles in the
# cudarc bindings, forwards proteon-search/cuda for GPU SW kernels,
# and embeds the .cu source via include_str! for runtime NVRTC.
RUN /opt/build-venv/bin/maturin build \
        --release \
        --out /wheels \
        --manifest-path proteon-connector/Cargo.toml \
        --features cuda

# Wheel 2: proteon (pure-Python wrapper). Same as :slim — the Python
# layer doesn't change between CPU and GPU builds; dispatch happens in
# the connector at import time based on cudarc's runtime probe.
RUN /opt/build-venv/bin/python -m build --wheel \
        --outdir /wheels packages/proteon \
    && ls -la /wheels

# ---------------------------------------------------------------------------
# Stage 2: Oracle binaries — built on the SAME glibc as the runtime.
#
# Same reasoning as the builder above: the runtime is
# nvidia/cuda:12.8.2-runtime-ubuntu24.04 (noble, glibc 2.39). Building
# oracles on a different-glibc base would leave them linked against
# symbols that don't exist on the runtime stage. ubuntu:24.04 keeps
# every binary in this image (Rust cdylib, USAlign, reduce, mkdssp,
# libcifpp) on the same glibc the runtime ships.
#
# noble ships gcc-13 + libstdc++-13 + cmake 3.28 in default apt, so
# neither ubuntu-toolchain-r PPA nor a Kitware CMake tarball is
# needed (libcifpp HEAD's C++20 <format> compiles cleanly on the
# default toolchain).
# ---------------------------------------------------------------------------
FROM ubuntu:24.04 AS oracles

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake git ca-certificates \
        wget tar xz-utils \
        python3 python3-dev \
        libboost-program-options-dev libboost-iostreams-dev libboost-date-time-dev \
        libboost-python-dev \
        libsqlite3-dev \
        zlib1g-dev libeigen3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

RUN git clone --depth 1 https://github.com/pylelab/USAlign.git && \
    cd USAlign && make USalign && \
    install -m 0755 USalign /usr/local/bin/USalign && \
    cd .. && rm -rf USAlign

RUN git clone --depth 1 https://github.com/rlabduke/reduce.git && \
    cmake -S reduce -B reduce/build -DCMAKE_BUILD_TYPE=Release && \
    cmake --build reduce/build -j"$(nproc)" && \
    install -m 0755 reduce/build/reduce_src/reduce /usr/local/bin/reduce && \
    install -m 0644 reduce/reduce_wwPDB_het_dict.txt /usr/local/share/reduce_wwPDB_het_dict.txt && \
    rm -rf reduce

ARG MMSEQS_VERSION=15-6f452
RUN wget -q "https://github.com/soedinglab/MMseqs2/releases/download/${MMSEQS_VERSION}/mmseqs-linux-avx2.tar.gz" -O /tmp/mmseqs.tar.gz && \
    tar -xzf /tmp/mmseqs.tar.gz -C /opt && \
    ln -s /opt/mmseqs/bin/mmseqs /usr/local/bin/mmseqs && \
    rm /tmp/mmseqs.tar.gz

# mkdssp (PDB-REDO/dssp) build chain. Slim builds the same chain on
# trixie's default cmake/gcc-14; noble's default cmake 3.28 + gcc-13
# satisfies the same C++20 <format> + libmcfp configure requirements
# without any extra PPAs.
#
# Pinned versions (closes #13). The triple is mutually compatible:
# dssp v4.6.1 requires `find_package(cifpp 10.0.2)`; libmcfp v1.4.2
# matches dssp 4.6.1's tested CPMFindPackage GIT_TAG hint. Pinning
# stops upstream main pushes from breaking the build silently.
ARG LIBMCFP_VERSION=v1.4.2
ARG LIBCIFPP_VERSION=v10.0.3
ARG DSSP_VERSION=v4.6.1
RUN git clone --depth 1 -b "${LIBMCFP_VERSION}" https://github.com/mhekkel/libmcfp.git && \
    cmake -S libmcfp -B libmcfp/build -DCMAKE_BUILD_TYPE=Release && \
    cmake --build libmcfp/build -j"$(nproc)" && \
    cmake --install libmcfp/build && \
    rm -rf libmcfp

RUN git clone --depth 1 -b "${LIBCIFPP_VERSION}" https://github.com/PDB-REDO/libcifpp.git && \
    cmake -S libcifpp -B libcifpp/build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCIFPP_DOWNLOAD_CCD=OFF \
        -DCIFPP_INSTALL_UPDATE_SCRIPT=OFF \
        -DBUILD_TESTING=OFF && \
    cmake --build libcifpp/build -j"$(nproc)" && \
    cmake --install libcifpp/build && \
    rm -rf libcifpp

RUN git clone --depth 1 -b "${DSSP_VERSION}" https://github.com/PDB-REDO/dssp.git && \
    cmake -S dssp -B dssp/build -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTING=OFF && \
    cmake --build dssp/build -j"$(nproc)" && \
    install -m 0755 dssp/build/mkdssp /usr/local/bin/mkdssp && \
    rm -rf dssp

# ---------------------------------------------------------------------------
# Stage 3: CUDA runtime — NVIDIA's 12.8.2 Ubuntu 24.04 (noble) base
# carries libcudart and libnvrtc; libcuda is forwarded from the host
# at run time via the NVIDIA Container Runtime (`docker run --gpus all`).
# noble ships Python 3.12 + libstdc++-13 in default apt — no PPAs.
#
# CUDA version: cudarc 0.19's cuda-12050 feature compiled against 12.5
# headers; CUDA's minor-version forward compat makes 12.8.2 runtime
# fine for code built against 12.5. (12.5+noble doesn't exist as an
# nvidia/cuda image tag; 12.8.2 is the lowest 12.x available on noble.)
# ---------------------------------------------------------------------------
FROM nvidia/cuda:12.8.2-runtime-ubuntu24.04 AS runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    REDUCE_BIN=/usr/local/bin/reduce \
    REDUCE_DB=/usr/local/share/reduce_wwPDB_het_dict.txt \
    USALIGN_BIN=/usr/local/bin/USalign \
    PROTEON_SEARCH_MMSEQS_BIN=/usr/local/bin/mmseqs \
    GMX=/usr/bin/gmx \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility

LABEL org.opencontainers.image.title="proteon-evident-cuda" \
      org.opencontainers.image.description="Proteon (CUDA) + oracle stack + EVIDENT CLI for replaying GPU-enabled manifest claims" \
      org.opencontainers.image.source="https://github.com/theGreatHerrLebert/proteon" \
      org.opencontainers.image.licenses="MIT"

# Runtime libs: noble's default python3 (3.12) matches the builder's
# wheel ABI; gcc/python3-dev for freesasa sdist build; gromacs for the
# AMBER96 fold-preservation claim; libgomp1/libstdc++6 for the
# source-built oracles. noble's default libstdc++6 is from gcc-14, which
# is newer than the gcc-13 the oracles stage links against, so the
# GLIBCXX_3.4.32+ symbols are present out of the box.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates wget \
        python3 python3-dev python3-venv python3-pip \
        gcc \
        gromacs \
        libgomp1 libstdc++6 libglib2.0-0 \
        libboost-program-options1.83.0 libboost-iostreams1.83.0 libboost-date-time1.83.0 \
    && rm -rf /var/lib/apt/lists/*

# Oracle binaries from stage 2.
COPY --from=oracles /usr/local/bin/USalign        /usr/local/bin/USalign
COPY --from=oracles /usr/local/bin/reduce         /usr/local/bin/reduce
COPY --from=oracles /usr/local/share/reduce_wwPDB_het_dict.txt \
                                                  /usr/local/share/reduce_wwPDB_het_dict.txt
COPY --from=oracles /opt/mmseqs                   /opt/mmseqs
COPY --from=oracles /usr/local/bin/mmseqs         /usr/local/bin/mmseqs
COPY --from=oracles /usr/local/bin/mkdssp         /usr/local/bin/mkdssp
COPY --from=oracles /usr/local/lib/libcifpp.so*   /usr/local/lib/
COPY --from=oracles /usr/local/share/libcifpp     /usr/local/share/libcifpp
RUN ldconfig

# Pip oracles + the proteon wheels from stage 1.
COPY --from=builder /wheels /tmp/wheels
RUN python3 -m pip install --no-cache-dir --break-system-packages \
        biopython \
        gemmi \
        freesasa \
        pydssp \
        openmm \
        pdbfixer \
        ball-py \
        pebble \
        numpy \
        pyyaml \
        pytest \
    && python3 -m pip install --no-cache-dir --break-system-packages \
        /tmp/wheels/proteon_connector-*.whl \
        /tmp/wheels/proteon-*.whl \
    && rm -rf /tmp/wheels

WORKDIR /workspace/proteon
COPY tests          ./tests/
COPY test-pdbs      ./test-pdbs/
COPY validation     ./validation/
COPY evident        ./evident/
COPY benchmark      ./benchmark/
COPY devdocs        ./devdocs/
COPY docs           ./docs/
COPY README.md THIRD_PARTY_NOTICES.md LICENSE VERSION ./

# Install the EVIDENT CLI from the vendored copy. Path differs from
# :slim because Ubuntu's noble Python 3.12 uses dist-packages
# (Debian/Ubuntu convention), not site-packages. Without this, `import
# validate_manifest` from inside evident.py fails with
# ModuleNotFoundError.
RUN install -m 0755 /workspace/proteon/evident/tools/evident.py \
                    /usr/local/bin/evident \
    && install -m 0644 /workspace/proteon/evident/tools/validate_manifest.py \
                    /usr/local/lib/python3.12/dist-packages/validate_manifest.py \
    && install -m 0755 /workspace/proteon/evident/scripts/docker-entrypoint.sh \
                    /usr/local/bin/evident-docker-entrypoint

# Entrypoint dispatch:
#
#   replay <claim-id>     run the claim's evidence.command in /workspace/proteon
#   render <release-tag>  lock the EVIDENT bundle + render reports under
#                         evident/reports/<release-tag>/
#   list | validate | …   pass-through to the vendored `evident` CLI
#   (no args)             default: list claims in the manifest
ENTRYPOINT ["evident-docker-entrypoint"]
CMD []
